local base = "https://raw.githubusercontent.com/CoolExploit/TestLua/main/NotifyLib/Pacompat/"

local list = {
    "core",
    "player",
    "prompt",
}

local api = {}

for _,m in ipairs(list) do
    local ok,mod = pcall(function()
        return loadstring(game:HttpGet(base..m..".lua"))()
    end)

    if ok and type(mod) == "table" then
        for k,v in pairs(mod) do
            api[k] = v
        end
    end
end

return api
