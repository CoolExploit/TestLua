local P = {}

function P.click(cd)
    if not cd then return end

    local r = P.r()
    local o = r.CFrame

    r.CFrame = cd.Parent.CFrame * CFrame.new(0,0,-2)
    task.wait()

    if fireclickdetector then
        fireclickdetector(cd)
    elseif firesignal then
        firesignal(cd.MouseClick)
    elseif getconnections then
        for _,v in ipairs(getconnections(cd.MouseClick)) do
            v:Fire(game.Players.LocalPlayer)
        end
    end

    r.CFrame = o
end

return P
