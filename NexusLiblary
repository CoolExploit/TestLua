local Util = {}

function Util.Tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play(); return t
end

function Util.Corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = r or Theme.CornerRadius; c.Parent = p; return c
end

function Util.Padding(p, t, b, l, r)
    local pad = Instance.new("UIPadding")
    pad.PaddingTop = UDim.new(0,t or 0); pad.PaddingBottom = UDim.new(0,b or 0)
    pad.PaddingLeft = UDim.new(0,l or 0); pad.PaddingRight = UDim.new(0,r or 0)
    pad.Parent = p; return pad
end

function Util.List(p, gap, dir, ha, va)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, gap or 0)
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.HorizontalAlignment = ha or Enum.HorizontalAlignment.Left
    l.VerticalAlignment   = va or Enum.VerticalAlignment.Top
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = p; return l
end

function Util.Stroke(p, col, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = col or Color3.fromRGB(60,60,70); s.Thickness = thick or 1
    s.Transparency = trans or 0; s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p; return s
end

function Util.Frame(parent, color, size, pos, clip)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = color or Theme.Surface
    f.Size = size or UDim2.new(1,0,0,40)
    f.Position = pos or UDim2.new(0,0,0,0)
    f.BorderSizePixel = 0; f.ClipsDescendants = clip or false
    f.BackgroundTransparency = 0; f.Parent = parent; return f
end

function Util.Label(parent, text, font, size, color, frameSize, pos, xa)
    local l = Instance.new("TextLabel")
    l.Text = text or ""; l.Font = font or Theme.FontRegular
    l.TextSize = size or 14; l.TextColor3 = color or Theme.TextPrimary
    l.BackgroundTransparency = 1
    l.Size = frameSize or UDim2.new(1,0,0,20)
    l.Position = pos or UDim2.new(0,0,0,0)
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = parent; return l
end

function Util.Btn(parent, text, color, size, pos)
    local b = Instance.new("TextButton")
    b.Text = text or ""; b.Font = Theme.FontSemiBold; b.TextSize = 13
    b.TextColor3 = Theme.TextPrimary; b.BackgroundColor3 = color or Theme.SurfaceLight
    b.Size = size or UDim2.new(1,0,0,36)
    b.Position = pos or UDim2.new(0,0,0,0)
    b.BorderSizePixel = 0; b.AutoButtonColor = false
    b.Parent = parent; return b
end

function Util.Click(parent, z)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1,0,1,0); b.BackgroundTransparency = 1
    b.Text = ""; b.ZIndex = parent.ZIndex + (z or 1); b.Parent = parent; return b
end

function Util.Ripple(frame)
    local r = Instance.new("Frame")
    r.Size = UDim2.new(0,0,0,0); r.AnchorPoint = Vector2.new(0.5,0.5)
    r.BackgroundColor3 = Color3.fromRGB(255,255,255)
    r.BackgroundTransparency = 0.75; r.BorderSizePixel = 0
    r.ZIndex = frame.ZIndex + 10
    Util.Corner(r, UDim.new(1,0))
    local mx = Mouse.X - frame.AbsolutePosition.X
    local my = Mouse.Y - frame.AbsolutePosition.Y
    r.Position = UDim2.new(0,mx,0,my); r.Parent = frame
    local sz = math.max(frame.AbsoluteSize.X, frame.AbsoluteSize.Y) * 2.5
    Util.Tween(r, TweenInfo.new(0.5,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {
        Size = UDim2.new(0,sz,0,sz), BackgroundTransparency = 1 })
    game:GetService("Debris"):AddItem(r, 0.55)
end

function Util.Drag(handle, target)
    local dragging, di, ds, sp = false, nil, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; ds = i.Position; sp = target.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement then di = i end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if i == di and dragging then
            local d = i.Position - ds
            target.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
        end
    end)
end

-- Scrolling frame helper
function Util.Scroll(parent, size, pos)
    local s = Instance.new("ScrollingFrame")
    s.Size = size or UDim2.new(1,0,1,0)
