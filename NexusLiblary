function Tab:AddTextbox(cfg)       self._order+=1; return self:_Reg(Elements.Textbox(self._scroll, cfg, self._order)) end
function Tab:AddKeybind(cfg)       self._order+=1; return self:_Reg(Elements.Keybind(self._scroll, cfg, self._order)) end
function Tab:AddColorPicker(cfg)   self._order+=1; return self:_Reg(Elements.ColorPicker(self._scroll, self._overlay, cfg, self._order)) end
function Tab:AddParagraph(cfg)     self._order+=1; return self:_Reg(Elements.Paragraph(self._scroll, cfg, self._order)) end
function Tab:AddDivider()          self._order+=1; return self:_Reg(Elements.Divider(self._scroll, self._order)) end
function Tab:AddBadge(cfg)         self._order+=1; return self:_Reg(Elements.Badge(self._scroll, cfg, self._order)) end
function Tab:AddSection(text)      self._order+=1; return self:_Reg(Elements.Section(self._scroll, text, self._order)) end
function Tab:AddLabel(text)        self._order+=1; return self:_Reg(Elements.Label(self._scroll, text, self._order)) end

