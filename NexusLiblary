function Elements.Slider(parent, cfg, order)
    local label    = cfg.Label or "Slider"
    local minV     = cfg.Min or 0
    local maxV     = cfg.Max or 100
    local default  = math.clamp(cfg.Default or minV, minV, maxV)
    local suffix   = cfg.Suffix or ""
    local step     = cfg.Step  -- nil = continuous
    local callback = cfg.Callback
    local value    = default
    local dragging = false

    local wrap = Util.Frame(parent, Theme.Background, UDim2.new(1,0,0,54))
    wrap.BackgroundTransparency = 1; wrap.LayoutOrder = order or 0

    local cont = Util.Frame(wrap, Theme.SurfaceLight, UDim2.new(1,0,1,0))
    Util.Corner(cont, Theme.CornerRadiusSm); Util.Stroke(cont, Color3.fromRGB(50,50,62), 1)
    Util.Padding(cont, 8, 8, 14, 14)

    local topRow = Util.Frame(cont, Theme.Background, UDim2.new(1,0,0,18))
    topRow.BackgroundTransparency = 1

    Util.Label(topRow, label, Theme.FontRegular, 13, Theme.TextSecondary, UDim2.new(0.65,0,1,0))

    local valLbl = Util.Label(topRow, string.format("%.1f%s", value, suffix),
        Theme.FontBold, 13, Theme.Accent,
        UDim2.new(0.35,0,1,0), UDim2.new(0.65,0,0,0), Enum.TextXAlignment.Right)

    local trackBg = Util.Frame(cont, Theme.SurfaceLighter, UDim2.new(1,0,0,6),
        UDim2.new(0,0,1,-4))
    trackBg.AnchorPoint = Vector2.new(0,1); Util.Corner(trackBg, UDim.new(1,0))

    local fill = Util.Frame(trackBg, Theme.Accent, UDim2.new(0,0,1,0))
    Util.Corner(fill, UDim.new(1,0))

    local thumb = Util.Frame(trackBg, Color3.fromRGB(255,255,255), UDim2.new(0,14,0,14))
    thumb.AnchorPoint = Vector2.new(0.5,0.5); thumb.Position = UDim2.new(0,0,0.5,0)
    Util.Corner(thumb, UDim.new(1,0)); Util.Stroke(thumb, Theme.Accent, 2, 0.3)

    local function Snap(v)
        if step and step > 0 then
            v = math.floor(v / step + 0.5) * step
        end
        return math.clamp(v, minV, maxV)
    end

    local function Apply(v, anim)
        value = Snap(v)
        local pct = (value - minV) / (maxV - minV)
        local info = anim and Theme.TweenFast or TweenInfo.new(0)
        Util.Tween(fill, info, {Size=UDim2.new(pct,0,1,0)})
        Util.Tween(thumb, info, {Position=UDim2.new(pct,0,0.5,0)})
        if step and step >= 1 then
            valLbl.Text = string.format("%d%s", math.floor(value), suffix)
        else
            valLbl.Text = string.format("%.1f%s", value, suffix)
        end
        if callback then task.spawn(callback, value) end
    end
    Apply(value, false)

    local function MV()
        local abs=trackBg.AbsolutePosition; local siz=trackBg.AbsoluteSize
        return minV + math.clamp((Mouse.X-abs.X)/siz.X,0,1)*(maxV-minV)
    end

    trackBg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=true; Apply(MV(),false) end
    end)
    thumb.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=true end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then Apply(MV(),false) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    trackBg.MouseEnter:Connect(function() Util.Tween(thumb, Theme.TweenFast, {Size=UDim2.new(0,16,0,16)}) end)
    trackBg.MouseLeave:Connect(function() if not dragging then Util.Tween(thumb, Theme.TweenFast, {Size=UDim2.new(0,14,0,14)}) end end)

    local api = {}
    function api:SetValue(v) Apply(v, true) end
    function api:GetValue()  return value end

    return wrap, api
end

