local NexusLib = {}
NexusLib._registeredKeys = {}

-- Register one or more valid access keys
function NexusLib:SetKey(...)
    for _, k in ipairs({...}) do
        KeySystem:AddKey(k)
    end
end

function NexusLib:CreateWindow(cfg)
    if type(cfg)=="string" then cfg = {Title=cfg} end

    -- Key system gate
    if cfg.Key then
        KeySystem:AddKey(cfg.Key)
    end

    local win = Window.new(cfg)

    -- If keys are registered, show the gate before opening
    local hasKeys = false
    for _ in pairs(KeySystem._validKeys) do hasKeys=true; break end

    if hasKeys and not KeySystem._verified then
        KeySystem:Show(win._sg,
            function()
                -- Success: open the window
                win:Open()
                task.delay(0.5, function()
                    Notif:Send("Access Granted", "Welcome! Menu is now unlocked.", "success", 4)
                end)
            end,
            function()
                -- Fail after 3 attempts
                Notif:Send("Access Denied", "Too many failed attempts.", "error", 5)
            end
        )
    else
        task.delay(0.3, function()
            win:Open()
            task.delay(0.6, function()
                Notif:Send("NexusLib v2.0", "RightShift to toggle  •  Premium UI", "success", 4)
            end)
        end)
    end

    return win
end

function NexusLib:GetConfig()  return Config  end
function NexusLib:GetInput()   return Input   end

function NexusLib:SetThemePreset(name, preset)
    Themes[name] = preset
end

