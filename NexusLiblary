local Tab = {}; Tab.__index = Tab

function Tab.new(cfg, sidebarParent, contentParent, overlay)
    local self = setmetatable({}, Tab)
    local name    = cfg.Name or "Tab"
    local icon    = cfg.Icon or ""

    self._active   = false
    self._elements = {}
    self._order    = 0
    self._overlay  = overlay
    self._name     = name

    -- Sidebar button
    local btn = Util.Frame(sidebarParent, Theme.Background, UDim2.new(1,0,0,40))
    btn.BackgroundTransparency = 1

    local activeBg = Util.Frame(btn, Theme.SurfaceLighter, UDim2.new(1,0,1,0))
    activeBg.BackgroundTransparency = 1; Util.Corner(activeBg, Theme.CornerRadiusSm)

    local indicator = Util.Frame(btn, Theme.Accent, UDim2.new(0,3,0.6,0), UDim2.new(0,0,0.2,0))
    indicator.BackgroundTransparency = 1; Util.Corner(indicator, UDim.new(1,0))

    local prefix = icon ~= "" and (icon .. "  ") or ""
    local tabLbl = Util.Label(btn, prefix..name, Theme.FontSemiBold, 13, Theme.TextMuted,
        UDim2.new(1,-18,1,0), UDim2.new(0,14,0,0))

    self._activeBg = activeBg; self._indicator = indicator; self._tabLbl = tabLbl
    self._clickBtn = Util.Click(btn)

    self._clickBtn.MouseEnter:Connect(function()
        if not self._active then
            Util.Tween(activeBg, Theme.TweenFast, {BackgroundTransparency=0.5})
            Util.Tween(tabLbl, Theme.TweenFast, {TextColor3=Theme.TextSecondary})
        end
    end)
    self._clickBtn.MouseLeave:Connect(function()
        if not self._active then
            Util.Tween(activeBg, Theme.TweenFast, {BackgroundTransparency=1})
            Util.Tween(tabLbl, Theme.TweenFast, {TextColor3=Theme.TextMuted})
        end
    end)

    -- Content scroll
    local scroll = Util.Scroll(contentParent)
    scroll.Visible = false
    Util.List(scroll, Theme.ElementPadding); Util.Padding(scroll, 12, 12, 12, 12)
    self._scroll = scroll

    return self
end

function Tab:SetActive(v)
    self._active = v; self._scroll.Visible = v
    if v then
        Util.Tween(self._activeBg,  Theme.TweenFast, {BackgroundTransparency=0})
        Util.Tween(self._indicator, Theme.TweenFast, {BackgroundTransparency=0})
        Util.Tween(self._tabLbl,    Theme.TweenFast, {TextColor3=Theme.Accent})
    else
        Util.Tween(self._activeBg,  Theme.TweenFast, {BackgroundTransparency=1})
        Util.Tween(self._indicator, Theme.TweenFast, {BackgroundTransparency=1})
        Util.Tween(self._tabLbl,    Theme.TweenFast, {TextColor3=Theme.TextMuted})
    end
end

function Tab:_Filter(q)
    q = q:lower()
    for _, e in ipairs(self._elements) do
        if q=="" then e.frame.Visible=true; continue end
        local found = false
        for _, d in ipairs(e.frame:GetDescendants()) do
            if (d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox"))
                and d.Text~="" and d.Text:lower():find(q,1,true) then
                found=true; break
            end
        end
        e.frame.Visible = found
    end
end

function Tab:_Reg(frame, api)
    table.insert(self._elements, {frame=frame, api=api}); return api
end

function Tab:AddButton(cfg)        self._order+=1; return self:_Reg(Elements.Button(self._scroll, cfg, self._order)) end
function Tab:AddToggle(cfg)        self._order+=1; return self:_Reg(Elements.Toggle(self._scroll, cfg, self._order)) end
function Tab:AddSlider(cfg)        self._order+=1; return self:_Reg(Elements.Slider(self._scroll, cfg, self._order)) end
