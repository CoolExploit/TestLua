    searchBox.PlaceholderText = "Search..."; searchBox.PlaceholderColor3 = Theme.TextMuted
    searchBox.Text = ""; searchBox.TextColor3 = Theme.TextPrimary
    searchBox.BackgroundTransparency = 1; searchBox.Font = Theme.FontRegular; searchBox.TextSize = 12
    searchBox.TextXAlignment = Enum.TextXAlignment.Left; searchBox.BorderSizePixel = 0
    searchBox.ClearTextOnFocus = false; searchBox.Size = UDim2.new(1,-20,1,0)
    searchBox.Position = UDim2.new(0,18,0,0); searchBox.Parent = searchWrap
    self._searchBox = searchBox

    -- Divider
    Util.Frame(sidebar, Color3.fromRGB(38,38,50), UDim2.new(1,0,0,1))

    -- Tab scroll
    local tabScroll = Instance.new("ScrollingFrame")
    tabScroll.Size = UDim2.new(1,0,1,-48); tabScroll.BackgroundTransparency = 1
    tabScroll.BorderSizePixel = 0; tabScroll.ScrollBarThickness = 0
    tabScroll.CanvasSize = UDim2.new(0,0,0,0); tabScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabScroll.Parent = sidebar; Util.List(tabScroll, 4)
    self._tabContainer = tabScroll

    -- Content area
    local contentArea = Util.Frame(body, Theme.Background,
        UDim2.new(1,-Theme.SidebarWidth,1,0), UDim2.new(0,Theme.SidebarWidth,0,0))
    contentArea.ClipsDescendants = true; self._contentArea = contentArea

    -- Search logic
    local conn = searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        if self._activeTab then self._activeTab:_Filter(searchBox.Text) end
    end)
    table.insert(self._conns, conn)

    -- Global keybind
    local kconn = UserInputService.InputBegan:Connect(function(inp, proc)
        if proc then return end
        if inp.KeyCode == self._keybind then self:Toggle() end
    end)
    table.insert(self._conns, kconn)

    return self
end

-- ── Animated Minimize  ─────────────────────────────────────
-- Slides body out downward + fades, morphs the button icon,
-- then collapses window to header-only height.
function Window:_Minimize()
    self._minimized = not self._minimized
    if self._minimized then
        -- 1. Morph button icon
        self._minBtn.Text = "▲"
        -- 2. Fade + slide body down
        Util.Tween(self._body, Theme.TweenMedium, {
            Position = UDim2.new(0,0,0,Theme.HeaderHeight+1+20),
            BackgroundTransparency = 1
        })
        -- 3. Collapse window after short delay
        task.delay(0.12, function()
            Util.Tween(self._win, Theme.TweenSlow, {
                Size = UDim2.new(0,Theme.WindowWidth,0,Theme.HeaderHeight)
            })
        end)
        -- 4. Shadow shrinks with window
        Util.Tween(self._shadow, Theme.TweenSlow, {
            BackgroundTransparency = 0.75
        })
    else
        -- 1. Expand window first
        self._minBtn.Text = "─"
        Util.Tween(self._win, Theme.TweenSlow, {
            Size = UDim2.new(0,Theme.WindowWidth,0,Theme.WindowHeight)
        })
        -- 2. Slide body back in + fade in after window grows
        task.delay(0.18, function()
            self._body.Position = UDim2.new(0,0,0,Theme.HeaderHeight+1+20)
            self._body.BackgroundTransparency = 1
            Util.Tween(self._body, Theme.TweenMedium, {
                Position = UDim2.new(0,0,0,Theme.HeaderHeight+1),
                BackgroundTransparency = 1
            })
        end)
        Util.Tween(self._shadow, Theme.TweenSlow, {BackgroundTransparency=0.55})
    end
end

function Window:Open()
    if self._open then return end
    self._open = true
    self._win.Size = UDim2.new(0,Theme.WindowWidth,0,8)
    self._win.BackgroundTransparency = 1; self._win.Visible = true
    self._shadow.BackgroundTransparency = 1
    Util.Tween(self._win, Theme.TweenBounce, {
        Size = UDim2.new(0,Theme.WindowWidth,0,Theme.WindowHeight),
        BackgroundTransparency = 0
    })
    Util.Tween(self._shadow, Theme.TweenMedium, {BackgroundTransparency=0.55})
end

function Window:Close()
    if not self._open then return end
    self._open = false
    Util.Tween(self._shadow, Theme.TweenFast, {BackgroundTransparency=1})
    Util.Tween(self._win, Theme.TweenMedium, {
        Size = UDim2.new(0,Theme.WindowWidth,0,8),
        BackgroundTransparency = 1
    })
    task.delay(0.3, function() self._win.Visible=false end)
end

function Window:Toggle()
    if self._open then self:Close() else self:Open() end
end

function Window:Notify(title, msg, nType, dur)
    Notif:Send(title, msg, nType, dur)
end

function Window:SetTheme(name)
    ApplyThemePreset(name)
    -- Live-update accent line
    self._accentLine.BackgroundColor3 = Theme.Accent
end

function Window:SetKeybind(key)
    self._keybind = key
end

function Window:SetAccentColor(color)
    Theme.Accent = color
    Theme.AccentDark = Color3.fromRGB(
        math.max(0,color.R*255-60)/255,
        math.max(0,color.G*255-60)/255,
        math.max(0,color.B*255-60)/255
    )
    self._accentLine.BackgroundColor3 = color
end

function Window:CreateTab(cfg)
    if type(cfg)=="string" then cfg = {Name=cfg} end
    local tab = Tab.new(cfg, self._tabContainer, self._contentArea, self._overlay)
    table.insert(self._tabs, tab)
    if #self._tabs==1 then tab:SetActive(true); self._activeTab=tab end

    tab._clickBtn.MouseButton1Click:Connect(function()
        if self._activeTab==tab then return end
        self._activeTab:SetActive(false)
        tab:SetActive(true); self._activeTab=tab; self._searchBox.Text=""
    end)
    return tab
end

function Window:Destroy()
    for _, c in ipairs(self._conns) do c:Disconnect() end
    self._sg:Destroy()
end

