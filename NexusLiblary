function Elements.Dropdown(parent, cfg, overlay, order)
    local label    = cfg.Label or "Dropdown"
    local options  = cfg.Options or {}
    local multi    = cfg.Multi == true
    local callback = cfg.Callback
    local selected = multi and {} or nil
    local open     = false
    local ITEM_H   = 30
    local PANEL_H  = math.min(#options, 6) * ITEM_H + 10

    local wrap = Util.Frame(parent, Theme.Background, UDim2.new(1,0,0,Theme.ElementHeight))
    wrap.BackgroundTransparency = 1; wrap.LayoutOrder = order or 0

    local header = Util.Frame(wrap, Theme.SurfaceLight, UDim2.new(1,0,1,0))
    Util.Corner(header, Theme.CornerRadiusSm); Util.Stroke(header, Color3.fromRGB(50,50,62), 1)

    Util.Label(header, label, Theme.FontRegular, 13, Theme.TextSecondary,
        UDim2.new(0.45,0,1,0), UDim2.new(0,14,0,0))

    local selLbl = Util.Label(header, "Select...", Theme.FontSemiBold, 12, Theme.TextMuted,
        UDim2.new(0.38,0,1,0), UDim2.new(0.45,0,0,0), Enum.TextXAlignment.Right)

    local chevron = Util.Label(header, "▾", Theme.FontBold, 14, Theme.Accent,
        UDim2.new(0,20,1,0), UDim2.new(1,-26,0,0), Enum.TextXAlignment.Center)

    -- Floating panel in overlay
    local panel = Util.Frame(overlay, Theme.Surface, UDim2.new(0,0,0,0))
    panel.Visible = false; panel.ZIndex = 990
    Util.Corner(panel, Theme.CornerRadius); Util.Stroke(panel, Color3.fromRGB(55,55,68), 1)
    panel.ClipsDescendants = true

    local panelScroll = Util.Scroll(panel)
    panelScroll.Size = UDim2.new(1,0,1,0)
    Util.List(panelScroll, 2); Util.Padding(panelScroll, 4, 4, 4, 4)

    local function GetSelText()
        if multi then
            local keys = {}; for k in pairs(selected) do table.insert(keys,k) end
            return #keys==0 and "Select..." or table.concat(keys, ", ")
        else
            return selected or "Select..."
        end
    end

    local itemBtns = {}

    for _, opt in ipairs(options) do
        local isSel = multi and selected[opt] or selected == opt

        local item = Util.Btn(panelScroll, "", Theme.Surface, UDim2.new(1,0,0,ITEM_H-2))
        item.TextXAlignment = Enum.TextXAlignment.Left; item.Font = Theme.FontRegular
        item.TextSize = 12; item.ZIndex = 991
        item.AutomaticSize = Enum.AutomaticSize.None
        Util.Corner(item, Theme.CornerRadiusSm); Util.Padding(item, 0, 0, 10, 0)
        table.insert(itemBtns, {btn=item, opt=opt})

        -- Check mark
        local check = Util.Label(item, isSel and "✓" or "", Theme.FontBold, 12, Theme.Accent,
            UDim2.new(0,16,1,0), UDim2.new(1,-20,0,0), Enum.TextXAlignment.Center)
        check.ZIndex = 992

        -- Option label inside button (separate from button text)
        local optLbl = Util.Label(item, opt, Theme.FontRegular, 12, Theme.TextSecondary,
            UDim2.new(1,-30,1,0), UDim2.new(0,8,0,0))
        optLbl.ZIndex = 992

        item.MouseEnter:Connect(function()
            Util.Tween(item, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLighter})
            Util.Tween(optLbl, Theme.TweenFast, {TextColor3=Theme.TextPrimary})
        end)
        item.MouseLeave:Connect(function()
            local sel = multi and selected[opt] or selected==opt
            Util.Tween(item, Theme.TweenFast, {BackgroundColor3=sel and Theme.AccentDark or Theme.Surface})
            Util.Tween(optLbl, Theme.TweenFast, {TextColor3=sel and Theme.Accent or Theme.TextSecondary})
        end)
        item.MouseButton1Click:Connect(function()
            if multi then
                selected[opt] = not selected[opt] or nil
                check.Text = selected[opt] and "✓" or ""
            else
                selected = opt; check.Text = "✓"
                -- clear other checks
                for _, ib in ipairs(itemBtns) do
                    if ib.opt ~= opt then
                        local c = ib.btn:FindFirstChildWhichIsA("TextLabel")
                        if c then c.Text = "" end
                    end
                end
                -- close if not multi
                open = false
                Util.Tween(panel, Theme.TweenFast, {Size=UDim2.new(0,panel.AbsoluteSize.X,0,0)})
                task.delay(0.15, function() panel.Visible=false end)
                Util.Tween(chevron, Theme.TweenFast, {Rotation=0})
                Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLight})
            end
            selLbl.Text = GetSelText()
            Util.Tween(selLbl, Theme.TweenFast, {TextColor3=Theme.Accent})
            if callback then task.spawn(callback, multi and selected or opt) end
        end)
    end

    local panelW = 0  -- will be set on open

    local function CloseDD()
        open = false
        Util.Tween(panel, Theme.TweenFast, {Size=UDim2.new(0,panelW,0,0), BackgroundTransparency=1})
        task.delay(0.18, function() if not open then panel.Visible=false; panel.BackgroundTransparency=0 end end)
        Util.Tween(chevron, Theme.TweenFast, {Rotation=0})
        Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLight})
    end

    local function OpenDD()
        open = true
        local ap = header.AbsolutePosition; local as = header.AbsoluteSize
        local sg = overlay.AbsoluteSize
        panelW = math.max(as.X, 200)
        local px = math.clamp(ap.X, 0, sg.X - panelW - 4)
        local py = ap.Y + as.Y + 4
        if py + PANEL_H > sg.Y - 10 then py = ap.Y - PANEL_H - 4 end
        panel.Position = UDim2.new(0,px,0,py)
        panel.Size = UDim2.new(0,panelW,0,0)
        panel.BackgroundTransparency = 1; panel.Visible = true
        Util.Tween(panel, Theme.TweenMedium, {Size=UDim2.new(0,panelW,0,PANEL_H), BackgroundTransparency=0})
        Util.Tween(chevron, Theme.TweenFast, {Rotation=180})
        Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLighter})
    end

    local function Toggle() if open then CloseDD() else OpenDD() end end

    local click = Util.Click(header)
    click.MouseButton1Click:Connect(Toggle)
    click.MouseEnter:Connect(function() if not open then Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLighter}) end end)
    click.MouseLeave:Connect(function() if not open then Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLight}) end end)

    UserInputService.InputBegan:Connect(function(inp)
        if not open then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        task.wait()
        if not open then return end
        local mx,my = Mouse.X,Mouse.Y
        local pp,ps = panel.AbsolutePosition, panel.AbsoluteSize
        local hp,hs = header.AbsolutePosition, header.AbsoluteSize
        local inP = mx>=pp.X and mx<=pp.X+ps.X and my>=pp.Y and my<=pp.Y+ps.Y
        local inH = mx>=hp.X and mx<=hp.X+hs.X and my>=hp.Y and my<=hp.Y+hs.Y
        if not inP and not inH then CloseDD() end
    end)

    local api = {}
    function api:GetSelected() return selected end
    function api:SetSelected(v)
        if multi then selected[v]=true else selected=v end
        selLbl.Text = GetSelText()
        Util.Tween(selLbl, Theme.TweenFast, {TextColor3=Theme.Accent})
    end
    function api:Close() if open then CloseDD() end end

    return wrap, api
end

