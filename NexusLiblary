function Notif:Send(title, msg, nType, dur)
    if not self._c then return end
    nType = nType or "info"; dur = dur or 4
    local col = nType=="error" and Theme.Danger or nType=="warning" and Theme.Warning
             or nType=="success" and Theme.Success or Theme.Info

    local wrap = Util.Frame(self._c, Theme.Surface, UDim2.new(1,0,0,0))
    wrap.ClipsDescendants = false; Util.Corner(wrap, Theme.CornerRadius)
    Util.Stroke(wrap, col, 1, 0.3)

    -- Icon badge
    local iconMap = {success="✓", error="✕", warning="⚠", info="ℹ"}
    local iconFrame = Util.Frame(wrap, col, UDim2.new(0,4,1,0))
    Util.Corner(iconFrame, Theme.CornerRadiusSm)

    Util.Label(wrap, iconMap[nType] or "ℹ", Theme.FontBold, 13, col,
        UDim2.new(0,22,0,20), UDim2.new(0,8,0,4), Enum.TextXAlignment.Center)
    Util.Label(wrap, title, Theme.FontBold, 13, Theme.TextPrimary,
        UDim2.new(1,-38,0,18), UDim2.new(0,32,0,7))
    Util.Label(wrap, msg, Theme.FontRegular, 11, Theme.TextSecondary,
        UDim2.new(1,-38,0,15), UDim2.new(0,32,0,26))

    -- Progress bar
    local pt = Util.Frame(wrap, Theme.SurfaceLighter, UDim2.new(1,-14,0,2), UDim2.new(0,7,1,-4))
    pt.AnchorPoint = Vector2.new(0,1); Util.Corner(pt, UDim.new(1,0))
    local pf = Util.Frame(pt, col, UDim2.new(1,0,1,0)); Util.Corner(pf, UDim.new(1,0))

    wrap.BackgroundTransparency = 1
    Util.Tween(wrap, Theme.TweenMedium, {Size=UDim2.new(1,0,0,58), BackgroundTransparency=0})
    Util.Tween(pf, TweenInfo.new(dur,Enum.EasingStyle.Linear), {Size=UDim2.new(0,0,1,0)})

    task.delay(dur, function()
        Util.Tween(wrap, Theme.TweenMedium, {Size=UDim2.new(1,0,0,0), BackgroundTransparency=1})
        task.wait(0.3); wrap:Destroy()
    end)
end

