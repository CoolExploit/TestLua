        UDim2.new(1,-20,0,12), UDim2.new(0,10,0,142), Enum.TextXAlignment.Left)
    rgbLbl.ZIndex = 1000

    local function Apply()
        color = Color3.fromHSV(h,s,v)
        swatch.BackgroundColor3 = color
        svImg.BackgroundColor3  = Color3.fromHSV(h,1,1)
        svCur.Position  = UDim2.new(s,0,1-v,0)
        hueCur.Position = UDim2.new(0,-3,h,0)
        local R,G,B = math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)
        hexBox.Text = string.format("#%02X%02X%02X",R,G,B)
        rgbLbl.Text = string.format("R:%d G:%d B:%d",R,G,B)
        if callback then task.spawn(callback, color) end
    end
    Apply()

    hexBox.FocusLost:Connect(function()
        local hex = hexBox.Text:gsub("[^%x]",""):upper()
        if #hex==6 then
            local r=tonumber(hex:sub(1,2),16); local g=tonumber(hex:sub(3,4),16); local b=tonumber(hex:sub(5,6),16)
            if r and g and b then color=Color3.fromRGB(r,g,b); h,s,v=Color3.toHSV(color); Apply() end
        end
    end)

    svImg.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=true end end)
    hueImg.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDrag=true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=false; hueDrag=false end end)
    UserInputService.InputChanged:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if svDrag then
            local a=svImg.AbsolutePosition; local sz=svImg.AbsoluteSize
            s=math.clamp((Mouse.X-a.X)/sz.X,0,1); v=1-math.clamp((Mouse.Y-a.Y)/sz.Y,0,1); Apply()
        elseif hueDrag then
            local a=hueImg.AbsolutePosition; local sz=hueImg.AbsoluteSize
            h=math.clamp((Mouse.Y-a.Y)/sz.Y,0,1); Apply()
        end
    end)

    local function Close()
        open=false
        Util.Tween(panel, Theme.TweenFast, {BackgroundTransparency=1})
        task.delay(0.15, function() if not open then panel.Visible=false; panel.BackgroundTransparency=0 end end)
        Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLight})
    end
    local function Open()
        open=true
        local ap=header.AbsolutePosition; local as_=header.AbsoluteSize; local sg=overlay.AbsoluteSize
        local px=math.clamp(ap.X,0,sg.X-PW-4)
        local py=ap.Y+as_.Y+4
        if py+PH>sg.Y-10 then py=ap.Y-PH-4 end
        panel.Position=UDim2.new(0,px,0,py); panel.BackgroundTransparency=1; panel.Visible=true
        Util.Tween(panel, Theme.TweenFast, {BackgroundTransparency=0})
        Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLighter})
    end

    local hClick = Util.Click(header)
    hClick.MouseButton1Click:Connect(function() if open then Close() else Open() end end)
    hClick.MouseEnter:Connect(function() if not open then Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLighter}) end end)
    hClick.MouseLeave:Connect(function() if not open then Util.Tween(header, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLight}) end end)
    swatch.MouseButton1Click:Connect(function() if open then Close() else Open() end end)
    xBtn.MouseButton1Click:Connect(Close)

    UserInputService.InputBegan:Connect(function(inp)
        if not open then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        task.wait()
        if not open then return end
        local mx,my=Mouse.X,Mouse.Y
        local pp,ps=panel.AbsolutePosition,panel.AbsoluteSize
        local hp,hs=header.AbsolutePosition,header.AbsoluteSize
        local inP=mx>=pp.X and mx<=pp.X+ps.X and my>=pp.Y and my<=pp.Y+ps.Y
        local inH=mx>=hp.X and mx<=hp.X+hs.X and my>=hp.Y and my<=hp.Y+hs.Y
        if not inP and not inH then Close() end
    end)

    local api = {}
    function api:GetColor() return color end
    function api:SetColor(c) color=c; h,s,v=Color3.toHSV(c); Apply() end

    return wrap, api
end

