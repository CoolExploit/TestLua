local KeySystem = {}
KeySystem._validKeys = {}
KeySystem._verified  = false

function KeySystem:AddKey(key)
    self._validKeys[tostring(key):upper():gsub("%s+","")] = true
end

-- Displays a blocking key-entry screen over the ScreenGui.
-- Calls onSuccess() if key matches, onFail() otherwise.
function KeySystem:Show(sg, onSuccess, onFail)
    if self._verified then onSuccess(); return end

    local overlay = Util.Frame(sg, Color3.fromRGB(0,0,0), UDim2.new(1,0,1,0))
    overlay.BackgroundTransparency = 0.3; overlay.ZIndex = 800

    local card = Util.Frame(sg, Theme.Surface, UDim2.new(0,420,0,240),
        UDim2.new(0.5,-210,0.5,-120))
    card.ZIndex = 801
    Util.Corner(card, Theme.CornerRadiusLg)
    Util.Stroke(card, Theme.Accent, 1, 0.3)

    -- Glow border pulse
    local stroke = card:FindFirstChildWhichIsA("UIStroke")
    local glowDir = true
    local conn; conn = RunService.Heartbeat:Connect(function()
        if not card.Parent then conn:Disconnect(); return end
        local t = stroke.Transparency + (glowDir and -0.02 or 0.02)
        if t <= 0 then glowDir=false elseif t >= 0.7 then glowDir=true end
        stroke.Transparency = math.clamp(t,0,0.7)
    end)

    Util.Label(card, "🔐  KEY REQUIRED", Theme.FontBold, 16, Theme.Accent,
        UDim2.new(1,0,0,30), UDim2.new(0,0,0,20), Enum.TextXAlignment.Center)
    Util.Label(card, "Enter your access key to continue", Theme.FontRegular, 12, Theme.TextSecondary,
        UDim2.new(1,0,0,18), UDim2.new(0,0,0,52), Enum.TextXAlignment.Center)

    -- Input box
    local inputWrap = Util.Frame(card, Theme.SurfaceLighter, UDim2.new(1,-40,0,36),
        UDim2.new(0,20,0,84))
    Util.Corner(inputWrap, Theme.CornerRadius)
    local inputStroke = Util.Stroke(inputWrap, Color3.fromRGB(60,60,72), 1)

    local box = Instance.new("TextBox")
    box.PlaceholderText = "XXXX-XXXX-XXXX"; box.PlaceholderColor3 = Theme.TextMuted
    box.Text = ""; box.TextColor3 = Theme.TextPrimary
    box.BackgroundTransparency = 1; box.Font = Theme.FontMono; box.TextSize = 14
    box.TextXAlignment = Enum.TextXAlignment.Center; box.BorderSizePixel = 0
    box.ClearTextOnFocus = false; box.Size = UDim2.new(1,-16,1,0)
    box.Position = UDim2.new(0,8,0,0); box.ZIndex = 802; box.Parent = inputWrap

    box.Focused:Connect(function() Util.Tween(inputStroke, Theme.TweenFast, {Color=Theme.Accent}) end)
    box.FocusLost:Connect(function() Util.Tween(inputStroke, Theme.TweenFast, {Color=Color3.fromRGB(60,60,72)}) end)

    -- Status label
    local statusLbl = Util.Label(card, "", Theme.FontSemiBold, 11, Theme.TextMuted,
        UDim2.new(1,-40,0,14), UDim2.new(0,20,0,126), Enum.TextXAlignment.Center)

    -- Confirm button
    local confirmBtn = Util.Btn(card, "CONFIRM KEY", Theme.Accent,
        UDim2.new(1,-40,0,38), UDim2.new(0,20,0,148))
    confirmBtn.TextColor3 = Color3.fromRGB(0,0,0); confirmBtn.Font = Theme.FontBold
    confirmBtn.TextSize = 13; confirmBtn.ZIndex = 802
    Util.Corner(confirmBtn, Theme.CornerRadius)

    -- Discord / link label
    Util.Label(card, "Get your key at discord.gg/nexuslib", Theme.FontRegular,
        10, Theme.TextMuted, UDim2.new(1,0,0,14), UDim2.new(0,0,0,200),
        Enum.TextXAlignment.Center)

    local attempts = 0
    local function TryKey()
        local entered = box.Text:upper():gsub("%s+","")
        if self._validKeys[entered] then
            self._verified = true
            Util.Tween(statusLbl, Theme.TweenFast, {TextColor3 = Theme.Success})
            statusLbl.Text = "✓  Access granted!"
            Util.Tween(confirmBtn, Theme.TweenFast, {BackgroundColor3 = Theme.Success})
            task.wait(0.6)
            conn:Disconnect()
            Util.Tween(card, Theme.TweenMedium, {BackgroundTransparency=1})
            Util.Tween(overlay, Theme.TweenMedium, {BackgroundTransparency=1})
            task.wait(0.3); card:Destroy(); overlay:Destroy()
            onSuccess()
        else
            attempts += 1
            Util.Tween(statusLbl, Theme.TweenFast, {TextColor3=Theme.Danger})
            statusLbl.Text = "✕  Invalid key  (attempt "..attempts..")"
            Util.Tween(card, Theme.TweenFast, {Position=UDim2.new(0.5,-215,0.5,-120)})
            task.wait(0.05)
            Util.Tween(card, Theme.TweenFast, {Position=UDim2.new(0.5,-205,0.5,-120)})
            task.wait(0.05)
            Util.Tween(card, Theme.TweenFast, {Position=UDim2.new(0.5,-210,0.5,-120)})
            if attempts >= 3 and onFail then
                task.wait(1); conn:Disconnect()
                card:Destroy(); overlay:Destroy()
                onFail()
            end
        end
    end

    confirmBtn.MouseButton1Click:Connect(TryKey)
    box.FocusLost:Connect(function(enter) if enter then TryKey() end end)
    Util.Ripple(confirmBtn)

    confirmBtn.MouseEnter:Connect(function()
        Util.Tween(confirmBtn, Theme.TweenFast, {BackgroundColor3 = Theme.AccentDark})
    end)
    confirmBtn.MouseLeave:Connect(function()
        Util.Tween(confirmBtn, Theme.TweenFast, {BackgroundColor3 = Theme.Accent})
    end)
end

