    s.ScrollBarThickness = 3; s.ScrollBarImageColor3 = Theme.Accent
    s.CanvasSize = UDim2.new(0,0,0,0)
    s.AutomaticCanvasSize = Enum.AutomaticSize.Y
    s.ScrollingDirection = Enum.ScrollingDirection.Y
    s.Parent = parent; return s
end

-- ============================================================
--  ADAPTIVE INPUT SYSTEM
--  Detects keyboard vs gamepad and adjusts element behavior
-- ============================================================
local Input = {}
Input.Mode = "Keyboard"   -- "Keyboard" | "Gamepad"
Input._callbacks = {}

local function _detectInput(inputType)
    local gp = {
        Enum.UserInputType.Gamepad1, Enum.UserInputType.Gamepad2,
        Enum.UserInputType.Gamepad3, Enum.UserInputType.Gamepad4,
    }
    for _, g in ipairs(gp) do
        if inputType == g then return "Gamepad" end
    end
    if inputType == Enum.UserInputType.Keyboard
    or inputType == Enum.UserInputType.MouseButton1
    or inputType == Enum.UserInputType.MouseMovement then
        return "Keyboard"
    end
    return nil
end

UserInputService.InputBegan:Connect(function(inp)
    local mode = _detectInput(inp.UserInputType)
    if mode and mode ~= Input.Mode then
        Input.Mode = mode
        for _, cb in ipairs(Input._callbacks) do pcall(cb, mode) end
    end
end)

function Input:OnModeChanged(cb)
    table.insert(self._callbacks, cb)
end

function Input:IsGamepad() return self.Mode == "Gamepad" end

