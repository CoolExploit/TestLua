-- Button
---------------------------------------------------------------
function Elements.Button(parent, cfg, order)
    local label    = cfg.Label or "Button"
    local callback = cfg.Callback
    local desc     = cfg.Description  -- optional tooltip-style sub-text

    local h = desc and 50 or Theme.ElementHeight
    local wrap = Util.Frame(parent, Theme.Background, UDim2.new(1,0,0,h))
    wrap.BackgroundTransparency = 1; wrap.LayoutOrder = order or 0

    local bg = Util.Frame(wrap, Theme.SurfaceLight, UDim2.new(1,0,1,0))
    bg.ClipsDescendants = true
    Util.Corner(bg, Theme.CornerRadiusSm)
    Util.Stroke(bg, Color3.fromRGB(50,50,62), 1)

    -- Accent left bar
    local bar = Util.Frame(bg, Theme.Accent, UDim2.new(0,3,0.55,0), UDim2.new(0,0,0.225,0))
    Util.Corner(bar, UDim.new(1,0))

    Util.Label(bg, label, Theme.FontSemiBold, 13, Theme.TextPrimary,
        UDim2.new(1,-36,0,20), UDim2.new(0,14,0,desc and 6 or 0))

    if desc then
        Util.Label(bg, desc, Theme.FontRegular, 11, Theme.TextMuted,
            UDim2.new(1,-36,0,14), UDim2.new(0,14,0,26))
    end

    local arrow = Util.Label(bg, "›", Theme.FontBold, 18, Theme.Accent,
        UDim2.new(0,20,1,0), UDim2.new(1,-24,0,0), Enum.TextXAlignment.Center)

    local click = Util.Click(bg)
    local lbl = bg:FindFirstChild("TextLabel") -- main label ref for hover

    click.MouseEnter:Connect(function()
        Util.Tween(bg, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLighter})
        Util.Tween(arrow, Theme.TweenFast, {Position=UDim2.new(1,-20,0,0), TextColor3=Theme.Accent})
    end)
    click.MouseLeave:Connect(function()
        Util.Tween(bg, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLight})
        Util.Tween(arrow, Theme.TweenFast, {Position=UDim2.new(1,-24,0,0)})
    end)
    click.MouseButton1Down:Connect(function()
        Util.Tween(bg, Theme.TweenFast, {BackgroundColor3=Theme.AccentDark})
        Util.Ripple(bg)
    end)
    click.MouseButton1Up:Connect(function()
        Util.Tween(bg, Theme.TweenFast, {BackgroundColor3=Theme.SurfaceLighter})
        if callback then task.spawn(callback) end
    end)

    local api = {}
    function api:SetLabel(t)
        for _, c in ipairs(bg:GetChildren()) do
            if c:IsA("TextLabel") then c.Text = t; break end
        end
    end
    function api:SetCallback(fn) callback = fn end

    return wrap, api
end

