local Notif = {}; Notif._c = nil

function Notif:Init(sg)
    local c = Util.Frame(sg, Theme.Background, UDim2.new(0,300,1,-20), UDim2.new(1,-310,0,10))
    c.BackgroundTransparency = 1; c.ZIndex = 600
