    Input:OnModeChanged(function(mode)
        modeLbl.Text = mode == "Gamepad" and "GP" or "KB"
        Util.Tween(modeChip, Theme.TweenFast, {
            BackgroundColor3 = mode=="Gamepad" and Theme.Info or Theme.SurfaceLighter
        })
        Util.Tween(modeLbl, Theme.TweenFast, {
            TextColor3 = mode=="Gamepad" and Color3.fromRGB(255,255,255) or Theme.TextMuted
        })
    end)

