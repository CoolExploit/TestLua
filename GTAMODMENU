--  LIBRARY ENTRY POINT
-- ============================================================
local NexusLib = {}

function NexusLib:CreateWindow(title, keybind)
    local window = Window.new(title)
    local toggleKey = keybind or Enum.KeyCode.RightShift

    -- Keybind listener
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == toggleKey then
            window:Toggle()
        end
    end)

    -- Show notification on load
    task.delay(0.5, function()
        if window._open then return end
        window:Open()
        task.delay(0.8, function()
            NotificationSystem:Notify(
                "NexusLib Loaded",
                "Press RightShift to toggle the menu",
                "success",
                4
            )
        end)
    end)

    return window
end

function NexusLib:SetTheme(themeOverride)
    for k, v in pairs(themeOverride) do
        Theme[k] = v
    end
end

function NexusLib:GetConfig()
    return Config
end

