    Util.Stroke(row, Color3.fromRGB(50, 50, 62), 1)

    local lbl = Util.Label(row, label, {
        Font      = Theme.FontRegular,
        Size      = 13,
        TextColor = Theme.TextSecondary,
        FrameSize = UDim2.new(1, -100, 1, 0),
        Position  = UDim2.new(0, 14, 0, 0),
    })

    local keyBtn = Util.Button(row, tostring(currentKey.Name), {
        Color    = Theme.SurfaceLighter,
        Size     = UDim2.new(0, 80, 0, 24),
        Position = UDim2.new(1, -90, 0.5, 0),
        TextSize = 11,
        TextColor = Theme.Accent,
        Font     = Theme.FontMono,
    })
    keyBtn.AnchorPoint = Vector2.new(0, 0.5)
    Util.Corner(keyBtn, Theme.CornerRadiusSm)
    Util.Stroke(keyBtn, Theme.Accent, 1, 0.5)

    local function SetListening(val)
        listening = val
        if val then
            keyBtn.Text = "Press key..."
            Util.Tween(keyBtn, Theme.TweenFast, {
                BackgroundColor3 = Theme.AccentDark,
                TextColor3 = Color3.fromRGB(255,255,255)
            })
        else
            keyBtn.Text = currentKey.Name
            Util.Tween(keyBtn, Theme.TweenFast, {
                BackgroundColor3 = Theme.SurfaceLighter,
                TextColor3 = Theme.Accent
            })
        end
    end

    keyBtn.MouseButton1Click:Connect(function()
        SetListening(not listening)
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
            currentKey = input.KeyCode
            SetListening(false)
            if callback then pcall(callback, currentKey) end
        end
