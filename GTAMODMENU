function Elements.Dropdown(parent, label, options, callback, layoutOrder)
    local selected = nil
    local open     = false
    local ITEM_H   = 30

    local wrap = Util.Frame(parent, Theme.Background,
        UDim2.new(1, 0, 0, Theme.ElementHeight))
    wrap.BackgroundTransparency = 1
    wrap.ClipsDescendants = false
    wrap.LayoutOrder = layoutOrder or 0

    local header = Util.Frame(wrap, Theme.SurfaceLight,
        UDim2.new(1, 0, 0, Theme.ElementHeight))
    Util.Corner(header, Theme.CornerRadiusSm)
    Util.Stroke(header, Color3.fromRGB(50,50,62), 1)

    Util.Label(header, label,
        Theme.FontRegular, 13, Theme.TextSecondary,
        UDim2.new(0.5, 0, 1, 0), UDim2.new(0, 14, 0, 0))

    local selLbl = Util.Label(header, "Select...",
        Theme.FontSemiBold, 12, Theme.TextMuted,
        UDim2.new(0.35, 0, 1, 0), UDim2.new(0.5, 0, 0, 0),
        Enum.TextXAlignment.Right)

    local chevron = Util.Label(header, "‚Ėĺ",
        Theme.FontBold, 14, Theme.Accent,
        UDim2.new(0, 20, 1, 0), UDim2.new(1, -26, 0, 0),
        Enum.TextXAlignment.Center)

    local panelFull = math.max(#options, 1) * ITEM_H + 8
    local panel = Util.Frame(wrap, Theme.Surface,
        UDim2.new(1, 0, 0, 0), UDim2.new(0, 0, 0, Theme.ElementHeight + 4))
    panel.ClipsDescendants = true
    panel.ZIndex = 20
    Util.Corner(panel, Theme.CornerRadiusSm)
    Util.Stroke(panel, Color3.fromRGB(50, 50, 62), 1)
    Util.ListLayout(panel, 2)
    Util.Padding(panel, 4, 4, 4, 4)

    for _, opt in ipairs(options) do
        local item = Util.Button(panel, opt, Theme.Surface,
            UDim2.new(1, 0, 0, ITEM_H - 2))
        item.TextXAlignment = Enum.TextXAlignment.Left
        item.Font           = Theme.FontRegular
        item.TextSize       = 12
        item.TextColor3     = Theme.TextSecondary
        item.ZIndex         = 21
        Util.Corner(item, Theme.CornerRadiusSm)
        Util.Padding(item, 0, 0, 8, 0)

        item.MouseEnter:Connect(function()
            Util.Tween(item, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter, TextColor3 = Theme.TextPrimary })
        end)
        item.MouseLeave:Connect(function()
            Util.Tween(item, Theme.TweenFast, {
                BackgroundColor3 = (selected == opt) and Theme.AccentDark or Theme.Surface,
                TextColor3 = (selected == opt) and Theme.Accent or Theme.TextSecondary,
            })
        end)
        item.MouseButton1Click:Connect(function()
            selected = opt
            selLbl.Text = opt
            Util.Tween(selLbl, Theme.TweenFast, { TextColor3 = Theme.Accent })
            open = false
            Util.Tween(panel,   Theme.TweenMedium, { Size = UDim2.new(1,0,0,0) })
            Util.Tween(chevron, Theme.TweenFast,   { Rotation = 0 })
            Util.Tween(header,  Theme.TweenFast,   { BackgroundColor3 = Theme.SurfaceLight })
            if callback then task.spawn(callback, opt) end
        end)
    end

    local function Toggle()
        open = not open
        if open then
            Util.Tween(panel,   Theme.TweenMedium, { Size = UDim2.new(1,0,0,panelFull) })
            Util.Tween(chevron, Theme.TweenFast,   { Rotation = 180 })
            Util.Tween(header,  Theme.TweenFast,   { BackgroundColor3 = Theme.SurfaceLighter })
        else
            Util.Tween(panel,   Theme.TweenMedium, { Size = UDim2.new(1,0,0,0) })
            Util.Tween(chevron, Theme.TweenFast,   { Rotation = 0 })
            Util.Tween(header,  Theme.TweenFast,   { BackgroundColor3 = Theme.SurfaceLight })
        end
    end

    local click = Util.ClickRegion(header)
    click.MouseButton1Click:Connect(Toggle)
    click.MouseEnter:Connect(function()
        if not open then Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter }) end
    end)
    click.MouseLeave:Connect(function()
        if not open then Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight }) end
    end)

    local api = {}
    function api:GetSelected() return selected end
    function api:SetSelected(v) selected = v; selLbl.Text = v; Util.Tween(selLbl, Theme.TweenFast, { TextColor3 = Theme.Accent }) end
    function api:Close() if open then Toggle() end end

    return wrap, api
end

