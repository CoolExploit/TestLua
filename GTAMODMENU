-- ‚ĒÄ‚ĒÄ Button ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function Elements.Button(parent, label, callback, layoutOrder)
    local wrapper = Util.Frame(parent, {
        Size        = UDim2.new(1, 0, 0, Theme.ElementHeight),
        Color       = Color3.fromRGB(0,0,0),
        LayoutOrder = layoutOrder or 0,
    })
    wrapper.BackgroundTransparency = 1

    local btn = Util.Button(wrapper, "", {
        Color       = Theme.SurfaceLight,
        Size        = UDim2.new(1, 0, 1, 0),
        Transparency = 0,
    })
    btn.ClipsDescendants = true
    Util.Corner(btn, Theme.CornerRadiusSm)
    Util.Stroke(btn, Color3.fromRGB(50, 50, 62), 1)

    -- Left accent line
    local accentBar = Util.Frame(btn, {
        Size  = UDim2.new(0, 3, 0.6, 0),
        Color = Theme.Accent,
        Position = UDim2.new(0, 0, 0.2, 0),
    })
    Util.Corner(accentBar, UDim.new(1, 0))

    local lbl = Util.Label(btn, label, {
        Font      = Theme.FontSemiBold,
        Size      = 13,
        TextColor = Theme.TextPrimary,
        FrameSize = UDim2.new(1, -30, 1, 0),
        Position  = UDim2.new(0, 16, 0, 0),
    })

    -- Arrow icon
    local arrow = Util.Label(btn, "‚Äļ", {
        Font      = Theme.FontBold,
        Size      = 18,
        TextColor = Theme.Accent,
        FrameSize = UDim2.new(0, 20, 1, 0),
        Position  = UDim2.new(1, -24, 0, 0),
        XAlign    = Enum.TextXAlignment.Center,
    })

    -- Hover effects
    btn.MouseEnter:Connect(function()
        Util.Tween(btn, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter })
        Util.Tween(lbl, Theme.TweenFast, { TextColor3 = Theme.Accent })
        Util.Tween(arrow, Theme.TweenFast, { Position = UDim2.new(1, -20, 0, 0) })
    end)

    btn.MouseLeave:Connect(function()
        Util.Tween(btn, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight })
        Util.Tween(lbl, Theme.TweenFast, { TextColor3 = Theme.TextPrimary })
        Util.Tween(arrow, Theme.TweenFast, { Position = UDim2.new(1, -24, 0, 0) })
    end)

    btn.MouseButton1Down:Connect(function()
        Util.Tween(btn, Theme.TweenFast, { BackgroundColor3 = Theme.AccentDark })
        Util.Ripple(btn)
    end)

    btn.MouseButton1Up:Connect(function()
        Util.Tween(btn, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter })
        if callback then pcall(callback) end
    end)

    return wrapper
end

