    end)
    header.MouseLeave:Connect(function()
        Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight })
    end)

    local api = {}
    function api:GetColor() return color end
    function api:SetColor(c)
        color = c
        h, s, v = Color3.toHSV(c)
        UpdateColor()
    end

    wrapper._api = api
