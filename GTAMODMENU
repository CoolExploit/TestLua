local Notif = {}; Notif._c = nil
function Notif:Init(sg)
    local c = Util.Frame(sg, Theme.Background,
        UDim2.new(0, 295, 1, -20), UDim2.new(1, -305, 0, 10))
    c.BackgroundTransparency = 1
    Util.ListLayout(c, 8)
    self._c = c
end

function Notif:Notify(title, msg, nType, dur)
    if not self._c then return end
    nType = nType or "info"; dur = dur or 4
    local col = nType == "error" and Theme.Danger
             or nType == "warning" and Theme.Warning
             or nType == "success" and Theme.Success
             or Theme.Accent

    -- Wrapper (grows from 0)
    local wrap = Util.Frame(self._c, Theme.Surface, UDim2.new(1, 0, 0, 0))
    wrap.ClipsDescendants = false
    Util.Corner(wrap, Theme.CornerRadius)
    Util.Stroke(wrap, col, 1, 0.4)

    -- Colored side bar
    local bar = Util.Frame(wrap, col, UDim2.new(0, 3, 0, 0), UDim2.new(0, 6, 0.5, 0))
    bar.AnchorPoint = Vector2.new(0, 0.5)
    Util.Corner(bar, UDim.new(1, 0))

    -- Text
    Util.Label(wrap, title,
        Theme.FontBold, 13, Theme.TextPrimary,
        UDim2.new(1, -24, 0, 18), UDim2.new(0, 18, 0, 7))
    Util.Label(wrap, msg,
        Theme.FontRegular, 11, Theme.TextSecondary,
        UDim2.new(1, -24, 0, 15), UDim2.new(0, 18, 0, 26))

    -- Progress bar
    local pt = Util.Frame(wrap, Theme.SurfaceLighter,
        UDim2.new(1, -14, 0, 2), UDim2.new(0, 7, 1, -4))
    pt.AnchorPoint = Vector2.new(0, 1)
    Util.Corner(pt, UDim.new(1, 0))
    local pf = Util.Frame(pt, col, UDim2.new(1, 0, 1, 0))
    Util.Corner(pf, UDim.new(1, 0))

    -- Animate in
    wrap.BackgroundTransparency = 1
    Util.Tween(wrap, Theme.TweenMedium, { Size = UDim2.new(1,0,0,56), BackgroundTransparency = 0 })
    Util.Tween(bar,  Theme.TweenMedium, { Size = UDim2.new(0, 3, 0, 32) })
    Util.Tween(pf, TweenInfo.new(dur, Enum.EasingStyle.Linear), { Size = UDim2.new(0,0,1,0) })

    task.delay(dur, function()
        Util.Tween(wrap, Theme.TweenMedium, { Size = UDim2.new(1,0,0,0), BackgroundTransparency = 1 })
        task.wait(0.3); wrap:Destroy()
    end)
end

-- ============================================================
--  ELEMENT BUILDERS
--  RULE: every builder returns (frame, api) as separate values.
--        `api` is a plain Lua table. `frame` is a Roblox Instance.
--        NEVER do frame.someCustomKey = anything.
-- ============================================================
local Elements = {}

---------------------------------------------------------------
--  Button
---------------------------------------------------------------
function Elements.Button(parent, label, callback, layoutOrder)
    -- Outer wrapper (transparent, just for sizing + layout)
    local wrap = Util.Frame(parent, Theme.Background,
        UDim2.new(1, 0, 0, Theme.ElementHeight))
    wrap.BackgroundTransparency = 1
    wrap.LayoutOrder = layoutOrder or 0

    local bg = Util.Frame(wrap, Theme.SurfaceLight, UDim2.new(1, 0, 1, 0))
    bg.ClipsDescendants = true
    Util.Corner(bg, Theme.CornerRadiusSm)
    Util.Stroke(bg, Color3.fromRGB(50, 50, 62), 1)

    -- Left accent bar
    local bar = Util.Frame(bg, Theme.Accent,
        UDim2.new(0, 3, 0.6, 0), UDim2.new(0, 0, 0.2, 0))
    Util.Corner(bar, UDim.new(1, 0))

    local lbl = Util.Label(bg, label,
        Theme.FontSemiBold, 13, Theme.TextPrimary,
        UDim2.new(1, -36, 1, 0), UDim2.new(0, 14, 0, 0))

    local arrow = Util.Label(bg, "‚Äļ",
        Theme.FontBold, 18, Theme.Accent,
        UDim2.new(0, 20, 1, 0), UDim2.new(1, -24, 0, 0),
        Enum.TextXAlignment.Center)

    local click = Util.ClickRegion(bg)

    click.MouseEnter:Connect(function()
        Util.Tween(bg,    Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter })
        Util.Tween(lbl,   Theme.TweenFast, { TextColor3 = Theme.Accent })
        Util.Tween(arrow, Theme.TweenFast, { Position = UDim2.new(1, -20, 0, 0) })
    end)
    click.MouseLeave:Connect(function()
        Util.Tween(bg,    Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight })
        Util.Tween(lbl,   Theme.TweenFast, { TextColor3 = Theme.TextPrimary })
        Util.Tween(arrow, Theme.TweenFast, { Position = UDim2.new(1, -24, 0, 0) })
    end)
    click.MouseButton1Down:Connect(function()
        Util.Tween(bg, Theme.TweenFast, { BackgroundColor3 = Theme.AccentDark })
        Util.Ripple(bg)
    end)
    click.MouseButton1Up:Connect(function()
        Util.Tween(bg, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter })
        if callback then task.spawn(callback) end
    end)

    -- api is a plain Lua table ‚ÄĒ NOT stored on any Instance
    local api = {}
    function api:SetLabel(t) lbl.Text = t end

    return wrap, api
end

---------------------------------------------------------------
--  Toggle
---------------------------------------------------------------
function Elements.Toggle(parent, label, default, callback, layoutOrder)
    local state = (default == true)

    local wrap = Util.Frame(parent, Theme.Background,
        UDim2.new(1, 0, 0, Theme.ElementHeight))
    wrap.BackgroundTransparency = 1
    wrap.LayoutOrder = layoutOrder or 0

    local row = Util.Frame(wrap, Theme.SurfaceLight, UDim2.new(1, 0, 1, 0))
    Util.Corner(row, Theme.CornerRadiusSm)
    Util.Stroke(row, Color3.fromRGB(50, 50, 62), 1)

    local lbl = Util.Label(row, label,
        Theme.FontRegular, 13, Theme.TextSecondary,
        UDim2.new(1, -72, 1, 0), UDim2.new(0, 14, 0, 0))

    local track = Util.Frame(row, Theme.SurfaceLighter,
        UDim2.new(0, 44, 0, 22), UDim2.new(1, -54, 0.5, 0))
    track.AnchorPoint = Vector2.new(0, 0.5)
    Util.Corner(track, UDim.new(1, 0))

    local thumb = Util.Frame(track, Theme.TextMuted,
        UDim2.new(0, 16, 0, 16), UDim2.new(0, 3, 0.5, 0))
    thumb.AnchorPoint = Vector2.new(0, 0.5)
    Util.Corner(thumb, UDim.new(1, 0))

    local function Refresh(animated)
        local info = animated and Theme.TweenMedium or TweenInfo.new(0)
        if state then
            Util.Tween(track, info, { BackgroundColor3 = Theme.Accent })
            Util.Tween(thumb, info, { Position = UDim2.new(1,-19,0.5,0), BackgroundColor3 = Color3.fromRGB(255,255,255) })
            Util.Tween(lbl,   info, { TextColor3 = Theme.TextPrimary })
        else
            Util.Tween(track, info, { BackgroundColor3 = Theme.SurfaceLighter })
            Util.Tween(thumb, info, { Position = UDim2.new(0,3,0.5,0),   BackgroundColor3 = Theme.TextMuted })
            Util.Tween(lbl,   info, { TextColor3 = Theme.TextSecondary })
        end
    end
    Refresh(false)

    local click = Util.ClickRegion(row)
    click.MouseButton1Click:Connect(function()
        state = not state
        Refresh(true)
        Util.Ripple(row)
        if callback then task.spawn(callback, state) end
    end)
    click.MouseEnter:Connect(function()
        Util.Tween(row, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter })
    end)
    click.MouseLeave:Connect(function()
        Util.Tween(row, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight })
    end)

    local api = {}
    function api:SetState(val)
        state = (val == true)
        Refresh(true)
        if callback then task.spawn(callback, state) end
    end
    function api:GetState() return state end

    return wrap, api
end

