    local thumb = Util.Frame(track, {
        Size     = UDim2.new(0, 16, 0, 16),
        Color    = Theme.TextMuted,
        Position = UDim2.new(0, 3, 0.5, 0),
    })
    thumb.AnchorPoint = Vector2.new(0, 0.5)
    Util.Corner(thumb, UDim.new(1, 0))

    local function UpdateVisual(animated)
        local tweenInfo = animated and Theme.TweenMedium or TweenInfo.new(0)
        if state then
            Util.Tween(track, tweenInfo, { BackgroundColor3 = Theme.Accent })
            Util.Tween(thumb, tweenInfo, {
                Position = UDim2.new(1, -19, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            })
            Util.Tween(lbl, tweenInfo, { TextColor3 = Theme.TextPrimary })
        else
            Util.Tween(track, tweenInfo, { BackgroundColor3 = Theme.SurfaceLighter })
            Util.Tween(thumb, tweenInfo, {
                Position = UDim2.new(0, 3, 0.5, 0),
                BackgroundColor3 = Theme.TextMuted
            })
            Util.Tween(lbl, tweenInfo, { TextColor3 = Theme.TextSecondary })
        end
    end

    UpdateVisual(false)

    -- Click anywhere on row
    local clickRegion = Instance.new("TextButton")
    clickRegion.Size = UDim2.new(1, 0, 1, 0)
    clickRegion.BackgroundTransparency = 1
    clickRegion.Text = ""
    clickRegion.ZIndex = row.ZIndex + 1
    clickRegion.Parent = row

    clickRegion.MouseButton1Click:Connect(function()
        state = not state
        UpdateVisual(true)
        Util.Ripple(row)
        if callback then pcall(callback, state) end
    end)

    -- Hover
    row.MouseEnter:Connect(function()
        Util.Tween(row, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter })
    end)
    row.MouseLeave:Connect(function()
        Util.Tween(row, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight })
    end)

    -- API
    local api = {}
    function api:SetState(val)
        state = val
        UpdateVisual(true)
    end
    function api:GetState()
        return state
    end

    wrapper._api = api
    return wrapper
end

-- ‚ĒÄ‚ĒÄ Slider ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function Elements.Slider(parent, label, min, max, default, callback, layoutOrder)
    local value = math.clamp(default or min, min, max)
    local dragging = false

    local wrapper = Util.Frame(parent, {
        Size        = UDim2.new(1, 0, 0, 52),
        Color       = Color3.fromRGB(0,0,0),
        LayoutOrder = layoutOrder or 0,
    })
    wrapper.BackgroundTransparency = 1

    local container = Util.Frame(wrapper, {
        Size  = UDim2.new(1, 0, 1, 0),
        Color = Theme.SurfaceLight,
    })
    Util.Corner(container, Theme.CornerRadiusSm)
    Util.Stroke(container, Color3.fromRGB(50, 50, 62), 1)
    Util.Padding(container, 8, 8, 14, 14)

    local topRow = Util.Frame(container, {
        Size  = UDim2.new(1, 0, 0, 18),
        Color = Color3.fromRGB(0,0,0),
    })
    topRow.BackgroundTransparency = 1

    local lbl = Util.Label(topRow, label, {
        Font      = Theme.FontRegular,
        Size      = 13,
        TextColor = Theme.TextSecondary,
        FrameSize = UDim2.new(0.7, 0, 1, 0),
    })

    local valueLbl = Util.Label(topRow, tostring(value), {
        Font      = Theme.FontBold,
        Size      = 13,
        TextColor = Theme.Accent,
        FrameSize = UDim2.new(0.3, 0, 1, 0),
        Position  = UDim2.new(0.7, 0, 0, 0),
        XAlign    = Enum.TextXAlignment.Right,
    })

    -- Track
    local trackBg = Util.Frame(container, {
        Size     = UDim2.new(1, 0, 0, 6),
        Color    = Theme.SurfaceLighter,
        Position = UDim2.new(0, 0, 1, -4),
    })
    trackBg.AnchorPoint = Vector2.new(0, 1)
    Util.Corner(trackBg, UDim.new(1, 0))

    local fill = Util.Frame(trackBg, {
        Size  = UDim2.new(0, 0, 1, 0),
        Color = Theme.Accent,
    })
    Util.Corner(fill, UDim.new(1, 0))

    -- Thumb
    local thumb = Util.Frame(trackBg, {
        Size  = UDim2.new(0, 14, 0, 14),
        Color = Color3.fromRGB(255, 255, 255),
    })
    thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    thumb.Position = UDim2.new(0, 0, 0.5, 0)
    Util.Corner(thumb, UDim.new(1, 0))

    -- Glow on thumb
    local thumbGlow = Instance.new("UIStroke")
    thumbGlow.Color     = Theme.Accent
    thumbGlow.Thickness = 2
    thumbGlow.Transparency = 0.3
    thumbGlow.Parent = thumb

    local function SetValue(v, animated)
        value = math.clamp(v, min, max)
        local pct = (value - min) / (max - min)
        local info = animated and Theme.TweenFast or TweenInfo.new(0)
        Util.Tween(fill, info, { Size = UDim2.new(pct, 0, 1, 0) })
        Util.Tween(thumb, info, { Position = UDim2.new(pct, 0, 0.5, 0) })
        valueLbl.Text = string.format("%.1f", value)
        if callback then pcall(callback, value) end
    end

    SetValue(value, false)

    -- Interaction
    local function GetValueFromMouse()
        local abs = trackBg.AbsolutePosition
        local siz = trackBg.AbsoluteSize
        local rel = math.clamp((Mouse.X - abs.X) / siz.X, 0, 1)
        return min + rel * (max - min)
    end

    trackBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            SetValue(GetValueFromMouse(), true)
        end
    end)

    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            SetValue(GetValueFromMouse(), false)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Hover on track
    trackBg.MouseEnter:Connect(function()
        Util.Tween(thumb, Theme.TweenFast, { Size = UDim2.new(0, 16, 0, 16) })
    end)
    trackBg.MouseLeave:Connect(function()
        if not dragging then
            Util.Tween(thumb, Theme.TweenFast, { Size = UDim2.new(0, 14, 0, 14) })
        end
    end)

    local api = {}
    function api:SetValue(v) SetValue(v, true) end
    function api:GetValue()  return value end

    wrapper._api = api
    return wrapper
end

-- ‚ĒÄ‚ĒÄ Dropdown ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function Elements.Dropdown(parent, label, options, callback, layoutOrder)
    local selected = nil
    local open = false
    local ITEM_H = 32

    local wrapper = Util.Frame(parent, {
        Size        = UDim2.new(1, 0, 0, Theme.ElementHeight),
        Color       = Color3.fromRGB(0,0,0),
        LayoutOrder = layoutOrder or 0,
        Clip        = false,
    })
    wrapper.BackgroundTransparency = 1
    wrapper.ClipsDescendants = false

    local header = Util.Button(wrapper, "", {
        Color = Theme.SurfaceLight,
        Size  = UDim2.new(1, 0, 0, Theme.ElementHeight),
    })
    header.ClipsDescendants = true
    Util.Corner(header, Theme.CornerRadiusSm)
    Util.Stroke(header, Color3.fromRGB(50, 50, 62), 1)

    local headerLbl = Util.Label(header, label, {
        Font      = Theme.FontRegular,
        Size      = 13,
        TextColor = Theme.TextSecondary,
        FrameSize = UDim2.new(1, -60, 1, 0),
        Position  = UDim2.new(0, 14, 0, 0),
    })

    local selectedLbl = Util.Label(header, "Select...", {
        Font      = Theme.FontSemiBold,
        Size      = 12,
        TextColor = Theme.TextMuted,
        FrameSize = UDim2.new(0.4, 0, 1, 0),
        Position  = UDim2.new(0.45, 0, 0, 0),
        XAlign    = Enum.TextXAlignment.Right,
    })

    local chevron = Util.Label(header, "‚Ėĺ", {
        Font      = Theme.FontBold,
        Size      = 14,
        TextColor = Theme.Accent,
        FrameSize = UDim2.new(0, 20, 1, 0),
        Position  = UDim2.new(1, -26, 0, 0),
        XAlign    = Enum.TextXAlignment.Center,
    })

    -- Dropdown panel
    local panelHeight = #options * ITEM_H + 8
    local panel = Util.Frame(wrapper, {
        Size     = UDim2.new(1, 0, 0, 0),
        Color    = Theme.Surface,
        Position = UDim2.new(0, 0, 0, Theme.ElementHeight + 4),
        Clip     = true,
    })
    panel.ZIndex = 10
    Util.Corner(panel, Theme.CornerRadiusSm)
    Util.Stroke(panel, Color3.fromRGB(50, 50, 62), 1)
    Util.Padding(panel, 4, 4, 4, 4)

    local itemLayout = Util.ListLayout(panel, 2)

    for _, opt in ipairs(options) do
        local item = Util.Button(panel, opt, {
            Color    = Color3.fromRGB(0,0,0),
            Size     = UDim2.new(1, 0, 0, ITEM_H - 4),
            TextSize = 13,
            TextColor = Theme.TextSecondary,
        })
        item.BackgroundTransparency = 1
        Util.Corner(item, Theme.CornerRadiusSm)
        item.TextXAlignment = Enum.TextXAlignment.Left

        Util.Padding(item, 0, 0, 10, 0)

        item.MouseEnter:Connect(function()
            Util.Tween(item, Theme.TweenFast, {
                BackgroundTransparency = 0,
                BackgroundColor3 = Theme.SurfaceLighter,
                TextColor3 = Theme.TextPrimary
            })
        end)
        item.MouseLeave:Connect(function()
            local isSelected = selected == opt
            Util.Tween(item, Theme.TweenFast, {
                BackgroundTransparency = isSelected and 0 or 1,
                BackgroundColor3 = Theme.AccentDark,
                TextColor3 = isSelected and Theme.Accent or Theme.TextSecondary
            })
        end)
        item.MouseButton1Click:Connect(function()
            selected = opt
            selectedLbl.Text = opt
            Util.Tween(selectedLbl, Theme.TweenFast, { TextColor3 = Theme.Accent })
            -- Close
            open = false
            Util.Tween(panel, Theme.TweenMedium, { Size = UDim2.new(1, 0, 0, 0) })
            Util.Tween(chevron, Theme.TweenFast, { Rotation = 0 })
            if callback then pcall(callback, opt) end
        end)
    end

    local function Toggle()
        open = not open
        if open then
            Util.Tween(panel, Theme.TweenMedium, { Size = UDim2.new(1, 0, 0, panelHeight) })
            Util.Tween(chevron, Theme.TweenFast, { Rotation = 180 })
            Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter })
        else
            Util.Tween(panel, Theme.TweenMedium, { Size = UDim2.new(1, 0, 0, 0) })
            Util.Tween(chevron, Theme.TweenFast, { Rotation = 0 })
            Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight })
        end
    end

    header.MouseButton1Click:Connect(Toggle)
    header.MouseEnter:Connect(function()
        if not open then Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter }) end
    end)
    header.MouseLeave:Connect(function()
        if not open then Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight }) end
    end)

    local api = {}
    function api:GetSelected() return selected end
    function api:SetSelected(v)
        selected = v
        selectedLbl.Text = v
        Util.Tween(selectedLbl, Theme.TweenFast, { TextColor3 = Theme.Accent })
    end

    wrapper._api = api
    return wrapper
end

