    Util.ListLayout(tabScroll, 4)
    self._tabContainer = tabScroll

    -- Content area
    local contentArea = Util.Frame(body, Theme.Background,
        UDim2.new(1,-Theme.SidebarWidth,1,0),
        UDim2.new(0,Theme.SidebarWidth,0,0))
    contentArea.ClipsDescendants = true
    self._contentArea = contentArea

    -- Search listener
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        if self._activeTab then self._activeTab:_Filter(searchBox.Text) end
    end)

    return self
end

function Window:_ToggleMinimize()
    self._minimized = not self._minimized
    Util.Tween(self._win, Theme.TweenSlow, {
        Size = self._minimized
            and UDim2.new(0, Theme.WindowWidth, 0, Theme.HeaderHeight)
            or  UDim2.new(0, Theme.WindowWidth, 0, Theme.WindowHeight)
    })
end

function Window:Open()
    if self._open then return end
    self._open = true
    self._win.Size = UDim2.new(0, Theme.WindowWidth, 0, 10)
    self._win.BackgroundTransparency = 1
    self._win.Visible    = true
    self._shadow.Visible = true
    Util.Tween(self._win, Theme.TweenBounce, {
        Size = UDim2.new(0, Theme.WindowWidth, 0, Theme.WindowHeight),
        BackgroundTransparency = 0,
    })
    Util.Tween(self._shadow, Theme.TweenMedium, { BackgroundTransparency = 0.72 })
end

function Window:Close()
    if not self._open then return end
    self._open = false
    Util.Tween(self._win, Theme.TweenMedium, {
        Size = UDim2.new(0, Theme.WindowWidth, 0, 10),
        BackgroundTransparency = 1,
    })
    Util.Tween(self._shadow, Theme.TweenFast, { BackgroundTransparency = 1 })
    task.delay(0.3, function()
        self._win.Visible    = false
        self._shadow.Visible = false
    end)
end

function Window:Toggle()
    if self._open then self:Close() else self:Open() end
end

function Window:Notify(title, message, nType, duration)
    Notif:Notify(title, message, nType, duration)
end

function Window:SetAccentColor(color)
    Theme.Accent    = color
    Theme.AccentDark = Color3.fromRGB(
        math.max(0, color.R*255-60)/255,
        math.max(0, color.G*255-60)/255,
        math.max(0, color.B*255-60)/255
    )
    self._accentLine.BackgroundColor3 = color
end

function Window:Destroy()
    self._sg:Destroy()
end

function Window:CreateTab(name)
    local tab = Tab.new(name, self._tabContainer, self._contentArea)
    table.insert(self._tabs, tab)

    if #self._tabs == 1 then
        tab:SetActive(true)
        self._activeTab = tab
    end

    tab._clickBtn.MouseButton1Click:Connect(function()
        if self._activeTab == tab then return end
        self._activeTab:SetActive(false)
        tab:SetActive(true)
        self._activeTab = tab
        self._searchBox.Text = ""
    end)

    return tab
end

