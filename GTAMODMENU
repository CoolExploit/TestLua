    -- Hue rainbow strip
    local hueImg = Instance.new("ImageLabel")
    hueImg.Size              = UDim2.new(0, 18, 0, 100)
    hueImg.Position          = UDim2.new(0, 154, 0, 10)
    hueImg.Image             = "rbxassetid://3641079264"
    hueImg.BackgroundTransparency = 1
    hueImg.BorderSizePixel   = 0
    hueImg.ZIndex            = 21
    Util.Corner(hueImg, Theme.CornerRadiusSm)
    hueImg.Parent = panel

    local hueCursor = Util.Frame(hueImg, Color3.fromRGB(255,255,255),
        UDim2.new(1,4,0,4), UDim2.new(0,-2,0,0))
    hueCursor.AnchorPoint = Vector2.new(0,0.5)
    hueCursor.ZIndex = 22
    Util.Corner(hueCursor, UDim.new(1,0))
    Util.Stroke(hueCursor, Color3.fromRGB(0,0,0), 1)

    -- Hex label
    local hexLbl = Util.Label(panel, "#000000",
        Theme.FontMono, 11, Theme.TextSecondary,
        UDim2.new(1,-20,0,20), UDim2.new(0,10,0,118))
    hexLbl.ZIndex = 21

    local function ApplyColor()
        color = Color3.fromHSV(h, s, v)
        swatch.BackgroundColor3 = color
        svImg.BackgroundColor3  = Color3.fromHSV(h, 1, 1)
        svCursor.Position       = UDim2.new(s, 0, 1-v, 0)
        hueCursor.Position      = UDim2.new(0, -2, h, 0)
        hexLbl.Text = string.format("#%02X%02X%02X",
            math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255))
        if callback then task.spawn(callback, color) end
    end
    ApplyColor()

    svImg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDrag = true end
    end)
    hueImg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then hueDrag = true end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDrag=false; hueDrag=false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if svDrag then
            local abs=svImg.AbsolutePosition; local siz=svImg.AbsoluteSize
            s = math.clamp((Mouse.X-abs.X)/siz.X, 0, 1)
            v = 1 - math.clamp((Mouse.Y-abs.Y)/siz.Y, 0, 1)
            ApplyColor()
        elseif hueDrag then
            local abs=hueImg.AbsolutePosition; local siz=hueImg.AbsoluteSize
            h = math.clamp((Mouse.Y-abs.Y)/siz.Y, 0, 1)
            ApplyColor()
        end
    end)

    local function TogglePanel()
        open = not open
        if open then
            Util.Tween(panel,  Theme.TweenMedium, { Size = UDim2.new(1,0,0,PICKER_H) })
            Util.Tween(header, Theme.TweenFast,   { BackgroundColor3 = Theme.SurfaceLighter })
        else
            Util.Tween(panel,  Theme.TweenMedium, { Size = UDim2.new(1,0,0,0) })
            Util.Tween(header, Theme.TweenFast,   { BackgroundColor3 = Theme.SurfaceLight })
        end
    end

    local hClick = Util.ClickRegion(header)
    hClick.MouseButton1Click:Connect(TogglePanel)
    hClick.MouseEnter:Connect(function()
        if not open then Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLighter }) end
    end)
    hClick.MouseLeave:Connect(function()
        if not open then Util.Tween(header, Theme.TweenFast, { BackgroundColor3 = Theme.SurfaceLight }) end
    end)
    swatch.MouseButton1Click:Connect(TogglePanel)

    local api = {}
    function api:GetColor() return color end
    function api:SetColor(c)
        color = c; h, s, v = Color3.toHSV(c); ApplyColor()
    end

    return wrap, api
end

