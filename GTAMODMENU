function NotificationSystem:Notify(title, message, notifType, duration)
    notifType = notifType or "info"
    duration  = duration or 4

    local accentColor = Theme.Accent
    if notifType == "error"   then accentColor = Theme.Danger  end
    if notifType == "warning" then accentColor = Theme.Warning end
    if notifType == "success" then accentColor = Theme.Success end

    local notif = Util.Frame(self._container, {
        Size  = UDim2.new(1, 0, 0, 0),
        Color = Theme.Surface,
        Clip  = false,
    })
    notif.ClipsDescendants = false
    notif.BackgroundTransparency = 0
    Util.Corner(notif, Theme.CornerRadius)
    Util.Stroke(notif, accentColor, 1, 0.3)

    -- Left accent bar
    local bar = Util.Frame(notif, {
        Size  = UDim2.new(0, 3, 1, -12),
        Color = accentColor,
        Position = UDim2.new(0, 6, 0.5, 0),
    })
    bar.AnchorPoint = Vector2.new(0, 0.5)
    Util.Corner(bar, UDim.new(1, 0))

    -- Content
    local content = Util.Frame(notif, {
        Size     = UDim2.new(1, -28, 1, 0),
        Color    = Color3.fromRGB(0,0,0),
        Position = UDim2.new(0, 20, 0, 0),
    })
    content.BackgroundTransparency = 1

    local titleLbl = Util.Label(content, title, {
        Font      = Theme.FontBold,
        Size      = 13,
        TextColor = Theme.TextPrimary,
        FrameSize = UDim2.new(1, -10, 0, 18),
        Position  = UDim2.new(0, 0, 0, 8),
    })

    local msgLbl = Util.Label(content, message, {
        Font      = Theme.FontRegular,
        Size      = 12,
        TextColor = Theme.TextSecondary,
        FrameSize = UDim2.new(1, -10, 0, 16),
        Position  = UDim2.new(0, 0, 0, 28),
        Truncate  = Enum.TextTruncate.AtEnd,
    })

    -- Progress bar
    local progressBg = Util.Frame(notif, {
        Size     = UDim2.new(1, -12, 0, 2),
        Color    = Theme.SurfaceLighter,
        Position = UDim2.new(0, 6, 1, -6),
    })
    progressBg.AnchorPoint = Vector2.new(0, 1)
    Util.Corner(progressBg, UDim.new(1, 0))

    local progressFill = Util.Frame(progressBg, {
        Size  = UDim2.new(1, 0, 1, 0),
        Color = accentColor,
    })
    Util.Corner(progressFill, UDim.new(1, 0))

    -- Animate in
    notif.Size = UDim2.new(1, 0, 0, 0)
    notif.BackgroundTransparency = 1
    Util.Tween(notif, Theme.TweenMedium, {
        Size = UDim2.new(1, 0, 0, 68),
        BackgroundTransparency = 0,
    })

    -- Progress tween
    Util.Tween(progressFill, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Size = UDim2.new(0, 0, 1, 0)
    })

    -- Animate out
    task.delay(duration, function()
        Util.Tween(notif, Theme.TweenMedium, {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
        })
        task.wait(0.3)
        notif:Destroy()
    end)

    return notif
end

