-- Filter elements by search query
function Tab:_Filter(query)
    query = query:lower()
    for _, el in ipairs(self._elements) do
        -- Try to find label text inside element
        local found = false
        if query == "" then
            found = true
        else
            for _, child in ipairs(el:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    if child.Text:lower():find(query, 1, true) then
                        found = true
                        break
                    end
                end
            end
        end
        el.Visible = found
    end
end

