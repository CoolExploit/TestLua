        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if svDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local abs = svFrame.AbsolutePosition
            local siz = svFrame.AbsoluteSize
            s = math.clamp((Mouse.X - abs.X) / siz.X, 0, 1)
            v = 1 - math.clamp((Mouse.Y - abs.Y) / siz.Y, 0, 1)
            UpdateColor()
        end
    end)

    -- Hue drag
    local hueDragging = false
    hueBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if hueDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local abs = hueBar.AbsolutePosition
            local siz = hueBar.AbsoluteSize
            h = math.clamp((Mouse.Y - abs.Y) / siz.Y, 0, 1)
            UpdateColor()
        end
    end)

    -- Toggle picker
    swatch.MouseButton1Click:Connect(function()
        open = not open
        if open then
            Util.Tween(panel, Theme.TweenMedium, { Size = UDim2.new(1, 0, 0, PICKER_H) })
        else
            Util.Tween(panel, Theme.TweenMedium, { Size = UDim2.new(1, 0, 0, 0) })
        end
