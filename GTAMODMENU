    body.ClipsDescendants = true

    -- Sidebar
    local sidebar = Util.Frame(body, Theme.Surface,
        UDim2.new(0,Theme.SidebarWidth,1,0))
    Util.ListLayout(sidebar, 4)
    Util.Padding(sidebar, 10, 10, 8, 8)

    -- Search box (plain Instance, no custom keys)
