function Tab.new(name, sidebarParent, contentParent)
    local self = setmetatable({}, Tab)
    self._active   = false
    -- Each entry: { frame = RobloxInstance, api = LuaTable }
    self._elements = {}
    self._order    = 0
    self._name     = name

    -- Sidebar button frame
    local btnFrame = Util.Frame(sidebarParent, Theme.Background,
        UDim2.new(1,0,0,40))
    btnFrame.BackgroundTransparency = 1
    self._sidebarFrame = btnFrame

    local activeBg = Util.Frame(btnFrame, Theme.SurfaceLighter, UDim2.new(1,0,1,0))
    activeBg.BackgroundTransparency = 1
    Util.Corner(activeBg, Theme.CornerRadiusSm)
    self._activeBg = activeBg

    local indicator = Util.Frame(btnFrame, Theme.Accent,
        UDim2.new(0,3,0.6,0), UDim2.new(0,0,0.2,0))
    indicator.BackgroundTransparency = 1
    Util.Corner(indicator, UDim.new(1,0))
    self._indicator = indicator

    local tabLbl = Util.Label(btnFrame, name,
        Theme.FontSemiBold, 13, Theme.TextMuted,
        UDim2.new(1,-18,1,0), UDim2.new(0,14,0,0))
    self._tabLbl = tabLbl

    self._clickBtn = Util.ClickRegion(btnFrame)

    self._clickBtn.MouseEnter:Connect(function()
        if not self._active then
            Util.Tween(activeBg, Theme.TweenFast, { BackgroundTransparency = 0.5 })
            Util.Tween(tabLbl,   Theme.TweenFast, { TextColor3 = Theme.TextSecondary })
        end
    end)
    self._clickBtn.MouseLeave:Connect(function()
        if not self._active then
            Util.Tween(activeBg, Theme.TweenFast, { BackgroundTransparency = 1 })
            Util.Tween(tabLbl,   Theme.TweenFast, { TextColor3 = Theme.TextMuted })
        end
    end)

    -- Scroll frame for content
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size               = UDim2.new(1,0,1,0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel    = 0
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = Theme.Accent
    scroll.CanvasSize         = UDim2.new(0,0,0,0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.ScrollingDirection = Enum.ScrollingDirection.Y
    scroll.Visible            = false
    scroll.Parent             = contentParent
    Util.ListLayout(scroll, Theme.ElementPadding)
    Util.Padding(scroll, 12, 12, 12, 12)
    self._scroll = scroll

    return self
end

function Tab:SetActive(val)
    self._active       = val
    self._scroll.Visible = val
    if val then
        Util.Tween(self._activeBg,  Theme.TweenFast, { BackgroundTransparency = 0 })
        Util.Tween(self._indicator, Theme.TweenFast, { BackgroundTransparency = 0 })
        Util.Tween(self._tabLbl,    Theme.TweenFast, { TextColor3 = Theme.Accent })
    else
        Util.Tween(self._activeBg,  Theme.TweenFast, { BackgroundTransparency = 1 })
        Util.Tween(self._indicator, Theme.TweenFast, { BackgroundTransparency = 1 })
        Util.Tween(self._tabLbl,    Theme.TweenFast, { TextColor3 = Theme.TextMuted })
    end
end

function Tab:_Filter(query)
    query = query:lower()
    for _, entry in ipairs(self._elements) do
        if query == "" then
            entry.frame.Visible = true
        else
            local found = false
            for _, desc in ipairs(entry.frame:GetDescendants()) do
                if (desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox"))
                    and desc.Text ~= ""
                    and desc.Text:lower():find(query, 1, true)
                then
                    found = true; break
                end
            end
            entry.frame.Visible = found
        end
    end
end

-- Register (frame, api) pair and return api to the caller
function Tab:_Reg(frame, api)
    table.insert(self._elements, { frame = frame, api = api })
    return api
end

function Tab:AddButton(label, callback)
    self._order += 1
    return self:_Reg(Elements.Button(self._scroll, label, callback, self._order))
end
function Tab:AddToggle(label, default, callback)
    self._order += 1
    return self:_Reg(Elements.Toggle(self._scroll, label, default, callback, self._order))
end
function Tab:AddSlider(label, minVal, maxVal, default, callback)
    self._order += 1
    return self:_Reg(Elements.Slider(self._scroll, label, minVal, maxVal, default, callback, self._order))
end
function Tab:AddDropdown(label, options, callback)
    self._order += 1
    return self:_Reg(Elements.Dropdown(self._scroll, label, options, callback, self._order))
end
function Tab:AddTextbox(label, placeholder, callback)
    self._order += 1
    return self:_Reg(Elements.Textbox(self._scroll, label, placeholder, callback, self._order))
end
function Tab:AddKeybind(label, default, callback)
    self._order += 1
    return self:_Reg(Elements.Keybind(self._scroll, label, default, callback, self._order))
end
function Tab:AddColorPicker(label, default, callback)
    self._order += 1
    return self:_Reg(Elements.ColorPicker(self._scroll, label, default, callback, self._order))
end
function Tab:AddLabel(text)
    self._order += 1
    return self:_Reg(Elements.Label(self._scroll, text, false, self._order))
end
function Tab:AddSection(text)
    self._order += 1
    return self:_Reg(Elements.Label(self._scroll, text, true, self._order))
end

