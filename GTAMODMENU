local Config = {}; Config._d = {}
function Config:Set(k, v) self._d[k] = v end
function Config:Get(k, def) local v = self._d[k]; return v ~= nil and v or def end
function Config:Export() return self._d end
function Config:Import(t) for k, v in pairs(t) do self._d[k] = v end end

