--  Slider
---------------------------------------------------------------
function Elements.Slider(parent, label, minVal, maxVal, default, callback, layoutOrder)
    minVal = minVal or 0; maxVal = maxVal or 100; default = default or minVal
    local value   = math.clamp(default, minVal, maxVal)
    local dragging = false

    local wrap = Util.Frame(parent, Theme.Background, UDim2.new(1, 0, 0, 52))
    wrap.BackgroundTransparency = 1
    wrap.LayoutOrder = layoutOrder or 0

    local container = Util.Frame(wrap, Theme.SurfaceLight, UDim2.new(1, 0, 1, 0))
    Util.Corner(container, Theme.CornerRadiusSm)
    Util.Stroke(container, Color3.fromRGB(50, 50, 62), 1)
    Util.Padding(container, 8, 8, 14, 14)

    local topRow = Util.Frame(container, Theme.Background, UDim2.new(1, 0, 0, 18))
    topRow.BackgroundTransparency = 1

    local lbl = Util.Label(topRow, label,
        Theme.FontRegular, 13, Theme.TextSecondary, UDim2.new(0.7, 0, 1, 0))

    local valLbl = Util.Label(topRow, string.format("%.1f", value),
        Theme.FontBold, 13, Theme.Accent,
        UDim2.new(0.3, 0, 1, 0), UDim2.new(0.7, 0, 0, 0),
        Enum.TextXAlignment.Right)

    local trackBg = Util.Frame(container, Theme.SurfaceLighter,
        UDim2.new(1, 0, 0, 6), UDim2.new(0, 0, 1, -4))
    trackBg.AnchorPoint = Vector2.new(0, 1)
    Util.Corner(trackBg, UDim.new(1, 0))

    local fill = Util.Frame(trackBg, Theme.Accent, UDim2.new(0, 0, 1, 0))
    Util.Corner(fill, UDim.new(1, 0))

    local thumb = Util.Frame(trackBg, Color3.fromRGB(255, 255, 255),
        UDim2.new(0, 14, 0, 14))
    thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    thumb.Position    = UDim2.new(0, 0, 0.5, 0)
    Util.Corner(thumb, UDim.new(1, 0))
    Util.Stroke(thumb, Theme.Accent, 2, 0.3)

    local function Apply(v, animated)
        value = math.clamp(v, minVal, maxVal)
        local pct  = (value - minVal) / (maxVal - minVal)
        local info = animated and Theme.TweenFast or TweenInfo.new(0)
        Util.Tween(fill,  info, { Size = UDim2.new(pct, 0, 1, 0) })
        Util.Tween(thumb, info, { Position = UDim2.new(pct, 0, 0.5, 0) })
        valLbl.Text = string.format("%.1f", value)
        if callback then task.spawn(callback, value) end
    end
    Apply(value, false)

    local function MouseVal()
        local abs = trackBg.AbsolutePosition; local siz = trackBg.AbsoluteSize
        return minVal + math.clamp((Mouse.X - abs.X) / siz.X, 0, 1) * (maxVal - minVal)
    end

    trackBg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; Apply(MouseVal(), false)
        end
    end)
    thumb.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            Apply(MouseVal(), false)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    trackBg.MouseEnter:Connect(function()
        Util.Tween(thumb, Theme.TweenFast, { Size = UDim2.new(0,16,0,16) })
    end)
    trackBg.MouseLeave:Connect(function()
        if not dragging then Util.Tween(thumb, Theme.TweenFast, { Size = UDim2.new(0,14,0,14) }) end
    end)

    local api = {}
    function api:SetValue(v) Apply(v, true) end
    function api:GetValue()  return value end
    function api:SetMin(v)   minVal = v; Apply(value, false) end
    function api:SetMax(v)   maxVal = v; Apply(value, false) end

    return wrap, api
end

