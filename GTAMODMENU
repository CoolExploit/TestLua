local NexusLib = {}

function NexusLib:CreateWindow(title, keybind)
    local win = Window.new(title)
    local key = keybind or Enum.KeyCode.RightShift

    UserInputService.InputBegan:Connect(function(inp, processed)
        if processed then return end
        if inp.KeyCode == key then win:Toggle() end
    end)

    task.delay(0.3, function()
        win:Open()
        task.delay(0.7, function()
            Notif:Notify("NexusLib v1.1", "RightShift to toggle  ‚ÄĘ  Bug-free!", "success", 5)
        end)
    end)

    return win
end

function NexusLib:GetConfig()
    return Config
end

function NexusLib:SetTheme(overrides)
    for k, v in pairs(overrides) do Theme[k] = v end
end

