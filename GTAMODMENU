    Util.Corner(closeBtn, Theme.CornerRadiusSm)

    minBtn.MouseEnter:Connect(function()
        Util.Tween(minBtn, Theme.TweenFast, { BackgroundColor3 = Color3.fromRGB(55,55,70), TextColor3 = Theme.TextPrimary })
    end)
    minBtn.MouseLeave:Connect(function()
        Util.Tween(minBtn, Theme.TweenFast, { BackgroundColor3 = Color3.fromRGB(40,40,52), TextColor3 = Theme.TextSecondary })
    end)
    closeBtn.MouseEnter:Connect(function()
        Util.Tween(closeBtn, Theme.TweenFast, { BackgroundColor3 = Theme.Danger, TextColor3 = Color3.fromRGB(255,255,255) })
